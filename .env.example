# Strapi base URL (no trailing slash)
CMS_URL=http://localhost:1337

# Strapi API token with read access to published content
# (Settings -> API Tokens in the Strapi admin)
CMS_API_TOKEN=

# Shared secret checked against the x-webhook-secret header sent by
# Strapi's webhook -> see src/app/api/revalidate/route.ts
CMS_WEBHOOK_SECRET=

# Hostname only (no protocol) for next/image remotePatterns -- see next.config.ts
NEXT_PUBLIC_CMS_MEDIA_HOST=localhost
